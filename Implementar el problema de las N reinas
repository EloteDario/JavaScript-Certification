function isValidPosition(board, row, col) {
let isValid = true

  // Horizontal
  for (let v = 0; v < board.length; v++) {
    if (board[row][v] === "Q") {
      isValid = false
    }
  }

  // Vertical
  for (let u = 0; u < board.length; u++) {
    if (board[u][col] === "Q") {
      isValid = false
    }
  }

  //Diagonal derecha arriba
  for (let i = row - 1, j = col + 1; i >= 0 && j < board.length; i--, j++) {
    if(board[i][j]=== "Q" ) {
      isValid = false
    }
  }

  //Diagonas izquierda arriba
  for (let a = row - 1, d = col - 1; a >= 0 && d >= 0; a--, d--) {
    if(board[a][d] === "Q") {
      isValid = false
    }
  }
  //Diagonal izquierda abajo
  for (let a = row + 1, d = col - 1; a < board.length && d >= 0; a++, d--) {
    if(board[a][d] === "Q") {
      isValid = false
    }
  }
  //diagonal derecha abajo
  for (let a = row + 1, d = col + 1; a < board.length && d < board.length; a++, d++) {
    if(board[a][d] === "Q") {
      isValid = false
    }
  }
  return isValid
}

function converter(board) {
  const returnedList = []

  for (let i = 0; i < board.length; i++) {
    for (let j = 0; j < board[i].length; j++) {
      if (board[i][j] === "Q") {
        returnedList.push(j)
      }
    }
  }
  return returnedList
}

function createBoard(n) {
  const board = []

  for (let i = 0; i < n; i++) {
    board.push(Array(n).fill("."))
  }
  return board
}

function dfsNQueens(n) {
  if(n < 1) {
    return []
  }
  // Crear Board y Lista de Soluciones
  const board = createBoard(n)

  const solutions = []

  //BackTracking
  function backTraking(filaActual) {

  //Caso Base
    // Si la posicion es segura y hay una Q en la ultima fila es una solucion
    if (filaActual === n) {

    //Si se cumple agregar la solucion a solutions pero antes la debes de pasar por la funcion "converter"
    solutions.push(converter(board))

    //Si se cumple fuerzas un retroceso a la fila de detras retornando sin valor, para que se vaya a la anterior llamada
    return
    }

  // Probar columna, intentar colocar una Q en la primera columna disponible
  for (let col = 0; col < n; col++) {

  //Validas si la posicion es segura.
  if (isValidPosition(board, filaActual, col)) {
    // Si la posicion es segura, dejas la Q y llamas a la funcion recursivamente para repetir el proceso
      board[filaActual][col] = "Q"
      backTraking(filaActual + 1)

  // SI no es segura quitas la Q que colocastes al probar la columna
      board[filaActual][col] = "."
      }
    }
  }

  //LLamas a la funcion BackTRaking desde la primera fila
  backTraking(0)

  return solutions
} 

