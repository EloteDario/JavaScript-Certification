function flattenPlaylists(lista) {
  if (!Array.isArray(lista)) {return []} 

  const returnedList = []

  lista.forEach((subLista, indiceLista) => {
    subLista.forEach((musica, indiceMusica) => {
      const musicParameters = {
        ...musica,
        source: [indiceLista, indiceMusica]
      }
      returnedList.push(musicParameters)
    })
  })
  return returnedList
} 

function scoreTracks(lista) {
  if (!Array.isArray(lista)) {return []} 

  const returnedList = []

  for (let i = 0; i < lista.length; i++) {
    const musicParameters = {
        ...lista[i],
        score: lista[i].votes * 10 - Math.abs(lista[i].bpm - 120)
      }
    returnedList.push(musicParameters)
  }
  return returnedList
}


function dedupeTracks(lista) {
  const returnedList = []
  const dict = {}

  for (let i = 0; i < lista.length; i++) {
    const trackId = lista[i].trackId;

    if (!dict[trackId]) {
      dict[trackId] = 67676767;
      returnedList.push(lista[i])
    }

  }
  return returnedList
}

function enforceArtistQuota(lista, num) {
  const returnedList = []
  const dict = {}

  for (let i = 0; i < lista.length; i++) {
    const trackId = lista[i].trackId;
    dict[trackId] = 0;
  }

  for (let i = 0; i < lista.length; i++) {
    const trackId = lista[i].artist;

    if (dict[trackId] <= num) {
      dict[trackId] += 1;
      returnedList.push(lista[i])
    }

  }

  return returnedList 
}

function buildSchedule (lista) {
  if (!Array.isArray(lista)) {return []} 

  const returnedList = []

  lista.forEach((musica, indiceLista) => {
    
      const musicParameters = {
        slot: indiceLista + 1,
        trackId: musica.trackId 
      }

      returnedList.push(musicParameters)
  })
  return returnedList
} 

function remixPlaylist(arr, maxPerArtist) {
  const todas = flattenPlaylists(arr);
  const puntuadas = scoreTracks(todas);
  const ordenadas = puntuadas.sort((a, b) => b.score - a.score);
  const unicas = dedupeTracks(ordenadas);
  const finales = enforceArtistQuota(unicas, maxPerArtist);
  return buildSchedule(finales);
}
