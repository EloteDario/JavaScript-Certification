function selectionSort(arr) {
for (let i = 0; i < arr.length; i++) {

  let smallestNum = i

  for (let t = i+1; t < arr.length; t++) {

    if (arr[t] < arr[smallestNum]) {

      smallestNum = t

    }

  }

  let temporal = arr[i]
  
  arr[i] = arr[smallestNum]
  arr[smallestNum] = temporal
  
}

  return arr

}

