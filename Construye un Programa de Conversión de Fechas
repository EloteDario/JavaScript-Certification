const currentDate = new Date()

const currentDateFormat = `Current Date and Time: ${currentDate}`
console.log(currentDateFormat)

function formatDateMMDDYYYY(currentDate) {
const formatted = currentDate.toLocaleDateString("en-US")
return `Formatted Date (MM/DD/YYYY): ${formatted}`;
}

console.log(formatDateMMDDYYYY(currentDate))

function formatDateLong (currentDate) {
const formatted = {
  year: "numeric",
  month: "long",
  day: "numeric",
};

return `Formatted Date (Month Day, Year): ${currentDate.toLocaleDateString("en-US", formatted)}`;
}

console.log(formatDateLong(currentDate))
